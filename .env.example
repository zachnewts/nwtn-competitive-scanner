# Tavily — web search API
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxx

# Anthropic — Claude API for signal analysis
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# Slack — bot token and channel for report delivery
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxxxxxxxxxxx
SLACK_CHANNEL_ID=C0XXXXXXXXX

# Database — SQLite file path
# Local: data/scanner.db
# Railway: /data/scanner.db (volume mount)
DB_PATH=data/scanner.db

# Report output directory
# Local: reports/
# Railway: /data/reports (volume mount)
REPORT_DIR=reports
